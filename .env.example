# Copy to .env and fill in. Only needed to deploy; the app itself needs nothing.
#
# Create a token at https://dash.cloudflare.com/profile/api-tokens with:
#   Account | Workers Scripts  | Edit
#   Zone    | Workers Routes   | Edit   (for the custom domain)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
